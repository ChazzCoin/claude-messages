{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "$comment": [
    "Galt hook config — see docs/decisions/bidirectional-claude-cli-architecture.md",
    "and tasks/backlog/TASK-080-claude-settings-hooks.md.",
    "",
    "Hook commands resolve via $GALT_HOOKS_DIR rather than the standard",
    "$CLAUDE_PROJECT_DIR because we pass this settings file with --settings",
    "on every spawn — including per-turn tasks where the subprocess cwd is",
    "the target repo, NOT the Galt repo. In that case $CLAUDE_PROJECT_DIR",
    "points at the target repo (which has no Galt hooks).",
    "",
    "$GALT_HOOKS_DIR is set explicitly by claude-cli.ts on every spawn so",
    "the path always resolves correctly regardless of cwd."
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$GALT_HOOKS_DIR/pre-bash-audit.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$GALT_HOOKS_DIR/pre-write-scope.sh"
          }
        ]
      },
      {
        "matcher": "mcp__github",
        "hooks": [
          {
            "type": "command",
            "command": "$GALT_HOOKS_DIR/pre-gh-auth.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$GALT_HOOKS_DIR/post-bash-mirror.sh"
          }
        ]
      }
    ]
  }
}
