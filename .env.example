# Copy to .env and fill in. Loaded by server/config.ts on boot.

# Server
PORT=3000
HOST=127.0.0.1

# Paths
# Defaults to ~/Library/Messages/chat.db on macOS — override only for testing.
CHAT_DB_PATH=
# App's own SQLite (drafts, watched contacts, rules). Defaults to ./data/app.db.
APP_DB_PATH=

# OpenAI — required once AI features come online (V1 step 3+).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — required for Claude CLI delegations (claude_ask tool).
# The CLI subprocess inherits this env var from the Node server and uses it
# directly, bypassing macOS Keychain OAuth (which doesn't work in subprocess
# contexts). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Firebase RTDB mirror — auto_notes are streamed to galt-messages RTDB
# for central viewing. Auth uses Application Default Credentials at
# ~/.config/gcloud/application_default_credentials.json (already a
# msb-logistics service account). No extra creds file needed.
#
# Default true. Set to 'false' to disable the mirror without touching code.
FIREBASE_MIRROR_ENABLED=true
# Override only if pointing at a different RTDB instance.
FIREBASE_DB_URL=https://galt-messages.firebaseio.com/
# When 'true', writes the raw inbound iMessage text alongside each note.
# Default false (redacted) — the AI summary is what's centrally viewed.
FIREBASE_MIRROR_INCLUDE_MESSAGE_TEXT=false
