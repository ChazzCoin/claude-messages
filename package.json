{
  "name": "galt",
  "version": "0.1.0",
  "private": true,
  "description": "Galt — local iMessage AI assistant. Reads chat.db, drafts replies in your voice, sends via AppleScript.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "serve": "tsx server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "remote:serve": "./bin/firebase serve --only hosting:galt-messages --host 127.0.0.1 --port 5050",
    "remote:deploy": "./bin/firebase deploy --only hosting:galt-messages"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.0.2",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
